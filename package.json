{
  "name": "script-runner",
  "version": "1.0.0",
  "description": "Self-hosted tool for writing and scheduling simple JavaScript scripts",
  "main": "server/index.js",
  "type": "module",
  "scripts": {
    "dev": "node server/index.js",
    "start": "node server/index.js",
    "build": "cd client && npm run build",
    "client:dev": "cd client && npm run dev",
    "client:install": "cd client && npm install",
    "reset": "node bin/reset.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "better-sqlite3": "^9.2.2",
    "node-cron": "^3.0.3",
    "multer": "^1.4.5-lts.1",
    "cors": "^2.8.5"
  },
  "devDependencies": {},
  "engines": {
    "node": ">=18.0.0"
  }
}
